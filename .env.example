# Database
DATABASE_URL=postgresql://fleet:fleet_secret@localhost:5432/fleetportal

# Redis
REDIS_URL=redis://localhost:6379

# Kafka / Redpanda
KAFKA_BROKERS=localhost:9092

# AI Agent (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Auth
JWT_SECRET=change_me_in_production_use_long_random_string

# Ports
API_PORT=3001
WEB_PORT=3000

# Web dashboard — HTTP via Next proxy /api/*; WebSocket direct to API
API_INTERNAL_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Mobile (Expo) — copy EXPO_PUBLIC_API_URL into apps/mobile/.env when testing on a real phone.
# localhost only works in the simulator; on iPhone use your Mac's Wi‑Fi IP (same as Metro, e.g. 192.168.1.4).
# EXPO_PUBLIC_API_URL=http://192.168.1.4:3001
EXPO_PUBLIC_API_URL=http://localhost:3001

# Logging
LOG_LEVEL=info
NODE_ENV=development

NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=
