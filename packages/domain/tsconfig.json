{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "composite": true
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/__tests__/**", "src/__tests__/**"]
}
